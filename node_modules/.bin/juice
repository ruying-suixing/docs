#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/c/Users/22790/vitepress-docs/node_modules/juice/node_modules:/mnt/c/Users/22790/vitepress-docs/node_modules:/mnt/c/Users/22790/vitepress-docs/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/c/Users/22790/vitepress-docs/node_modules/juice/node_modules:/mnt/c/Users/22790/vitepress-docs/node_modules:/mnt/c/Users/22790/vitepress-docs/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../juice/bin/juice" "$@"
else
  exec node  "$basedir/../juice/bin/juice" "$@"
fi
